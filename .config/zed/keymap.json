[
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j j": ["vim::SwitchMode", "Normal"],
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\u001b\r"],
      "cmd-t": "workspace::ActivatePaneUp",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-t": "terminal_panel::ToggleFocus",
    },
  },
]
