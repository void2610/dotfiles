{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://d25nyrwm2wqzzf.cloudfront.net",
    "OTEL_RESOURCE_ATTRIBUTES": "user.email=shuya.izumi@akariinc.co.jp"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "mcp__ide__*",
      "Bash(~/.claude/skills/discord-image/send.sh:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh Stop success"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '(.last_assistant_message // \"\") | contains(\"could not be parsed (retry also failed)\")' >/dev/null && exit 2 || exit 0",
            "asyncRewake": true,
            "rewakeMessage": "前ターンは tool call の parse 失敗（retry も失敗）で異常中断した。出力フォーマットを見直し、中断された作業を、同じ失敗を繰り返さぬよう必要なら別の手段で再開・完遂せよ。",
            "rewakeSummary": "tool callのparse失敗を検知。再開を促します"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh Notification"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && { br=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); st=$(git status --short 2>/dev/null); if [ \"$br\" != \"main\" ]; then lg=$(git log --oneline main..HEAD 2>/dev/null); sec=$(printf \"\\n\\n## main からの差分コミット\\n%s\" \"${lg:-(なし)}\"); else sec=\"\"; fi; jq -n --arg b \"$br\" --arg s \"$st\" --arg sec \"$sec\" '{hookSpecificOutput: {hookEventName: \"SessionStart\", additionalContext: (\"現在のブランチ: \" + $b + \"\\n\\n## git status --short\\n\" + (if $s == \"\" then \"(クリーン)\" else $s end) + $sec)}}'; } || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "akaridou@akari-awesome-cc-plugins": true,
    "statusline@akari-awesome-cc-plugins": true,
    "warp@claude-code-warp": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "akari-awesome-cc-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/AKARI-Inc/awesome-cc.git"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "language": "日本語",
  "effortLevel": "medium",
  "autoUpdatesChannel": "stable",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
