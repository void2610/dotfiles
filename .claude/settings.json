{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "mcp__*"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh Stop success"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh Notification"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "akaridou@akari-awesome-cc-plugins": true,
    "statusline@akari-awesome-cc-plugins": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "akari-awesome-cc-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/AKARI-Inc/awesome-cc.git"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "language": "日本語",
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
